EXTDIR="/usr/lib/enigma2/python/Plugins/Extensions/BouquetUpdater"

if [ -d "$EXTDIR" ]; then
    echo "Removing previous version..."
    rm -rf "$EXTDIR" > /dev/null 2>&1
